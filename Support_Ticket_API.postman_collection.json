{
  "info": {
    "name": "Support Ticket Management System",
    "description": "API collection for the FastAPI Support Ticket System backend (updated to current routes).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticket_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "agent_id",
      "value": "2",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Customer\",\n  \"email\": \"alice.c@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Agent",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Agent\",\n  \"email\": \"bob.a@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"agent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carol Admin\",\n  \"email\": \"carol.admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "register"
              ]
            }
          }
        },
        {
          "name": "Login (Auto-sets Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
                  "    console.log(\"Token set in collection variable: token\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "alice.c@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Categories",
      "item": [
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Payment\",\n  \"description\": \"Payment related support issues\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/categories",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "categories"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Tickets",
      "item": [
        {
          "name": "Create Ticket (Authenticated)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Payment\",\n  \"description\": \"My card gets declined during checkout.\",\n  \"priority\": \"high\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets"
              ]
            }
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/by-id/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "by-id",
                "{{ticket_id}}"
              ]
            }
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/my-tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "my-tickets"
              ]
            }
          }
        },
        {
          "name": "Get All Tickets (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets?page=1&page_size=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Tickets by Status (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/filter?status_code=open",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "filter"
              ],
              "query": [
                {
                  "key": "status_code",
                  "value": "open"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Tickets by Priority (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/by-priority?priority=high",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "by-priority"
              ],
              "query": [
                {
                  "key": "priority",
                  "value": "high"
                }
              ]
            }
          }
        },
        {
          "name": "Update Ticket Status (Agent/Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "{{ticket_id}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "Cancel Ticket with Reason (Agent/Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\",\n  \"reason\": \"Duplicate request\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "{{ticket_id}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "Assign Ticket (Admin)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}/assign?assign={{agent_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "{{ticket_id}}",
                "assign"
              ],
              "query": [
                {
                  "key": "assign",
                  "value": "{{agent_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Update Own Ticket (Customer)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Issue still persists after retry.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets/customer/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "customer",
                "{{ticket_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Comments",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket_id\": {{ticket_id}},\n  \"message\": \"I am looking into this issue right now.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/comments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "comments"
              ]
            }
          }
        },
        {
          "name": "Get Comments for Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/{{ticket_id}}/comments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                "{{ticket_id}}",
                "comments"
              ]
            }
          }
        }
      ]
    }
  ]
}
