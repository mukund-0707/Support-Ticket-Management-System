{
  "info": {
    "name": "Support Ticket Management System",
    "description": "API collection for the FastAPI Support Ticket System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Customer\",\n  \"email\": \"alice.c@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            }
          }
        },
        {
          "name": "Register Agent",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Agent\",\n  \"email\": \"bob.a@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"agent\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            }
          }
        },
        {
          "name": "Login (Auto-sets Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.access_token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.access_token);",
                  "    console.log(\"Token automatically set for future requests.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "alice.c@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Tickets",
      "item": [
        {
          "name": "Create Ticket (Customer)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Payment failed\",\n  \"description\": \"I tried to pay but my card was declined.\",\n  \"priority\": \"high\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets"]
            }
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/my-tickets",
              "host": ["{{base_url}}"],
              "path": ["tickets", "my-tickets"]
            }
          }
        },
        {
          "name": "Get All Tickets (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets?page=1&page_size=10",
              "host": ["{{base_url}}"],
              "path": ["tickets"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/by-id/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "by-id", "1"]
            }
          }
        },
        {
          "name": "Filter Tickets by Status (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/filter?status_code=open",
              "host": ["{{base_url}}"],
              "path": ["tickets", "filter"],
              "query": [
                {
                  "key": "status_code",
                  "value": "open"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Tickets by Priority (Agent/Admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/by-priority?priority=high",
              "host": ["{{base_url}}"],
              "path": ["tickets", "by-priority"],
              "query": [
                {
                  "key": "priority",
                  "value": "high"
                }
              ]
            }
          }
        },
        {
          "name": "Update Ticket Status (Agent/Admin)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/1/status?ticket_status=in_progress",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "status"],
              "query": [
                {
                  "key": "ticket_status",
                  "value": "in_progress"
                }
              ]
            }
          }
        },
        {
          "name": "Assign Ticket (Admin)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/1/assign?assign=2",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "assign"],
              "query": [
                {
                  "key": "assign",
                  "value": "2"
                }
              ]
            }
          }
        },
        {
          "name": "Update Own Ticket (Customer)",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"I tried again and it still failed.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/tickets/customer/1",
              "host": ["{{base_url}}"],
              "path": ["tickets", "customer", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Comments",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket_id\": 1,\n  \"message\": \"I am looking into this issue right now.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/comments",
              "host": ["{{base_url}}"],
              "path": ["comments"]
            }
          }
        },
        {
          "name": "Get Comments for Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/1/comments",
              "host": ["{{base_url}}"],
              "path": ["tickets", "1", "comments"]
            }
          }
        }
      ]
    }
  ]
}
